# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted to native line endings on checkout.
*.js text
*.ts text
*.tsx text
*.jsx text
*.json text
*.css text
*.scss text
*.html text
*.md text
*.yaml text
*.yml text
*.xml text
*.sh text
*.bat text
*.env text
*.toml text
*.prisma text

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.mp4 binary
*.mp3 binary
*.wav binary

# Prisma schema should use LF
schema.prisma text eol=lf

# Migration files should use LF
prisma/migrations/**/*.sql text eol=lf

# Lock files should use LF
package-lock.json text eol=lf
*.lock text eol=lf

# Shell scripts should use LF and be executable
*.sh text eol=lf
.git/hooks/* text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Large files - use Git LFS (uncomment if needed)
# *.psd filter=lfs diff=lfs merge=lfs -text
# *.zip filter=lfs diff=lfs merge=lfs -text
