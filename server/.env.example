# Server

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soul_yatri?schema=public
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters-long-with-special-chars-!@#$%
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Security
IP_SALT=soul-yatri-ip-salt-unique-random-string
BCRYPT_ROUNDS=12

# Optional: Rate Limiting (if using Redis)
# REDIS_URL=redis://localhost:6379

# Optional: Storage (for file uploads)
# STORAGE_PROVIDER=memory
# STORAGE_BUCKET=soul-yatri-uploads
# STORAGE_REGION=ap-south-1
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# MAX_FILE_SIZE=5242880

# Optional: Email
# EMAIL_PROVIDER=console
# EMAIL_API_KEY=your-email-api-key
# EMAIL_FROM=Soul Yatri <noreply@soulyatri.com>

# Optional: Payment (Razorpay)
# RAZORPAY_KEY_ID=your-razorpay-key-id
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Optional: Video (Daily.co)
# DAILY_API_KEY=your-daily-api-key

# Optional: AI (OpenAI)
# OPENAI_API_KEY=your-openai-api-key
# AI_MODEL=gpt-4o-mini
# AI_MAX_TOKENS=1000
