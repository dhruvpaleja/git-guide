# ============================================
# Soul Yatri - Environment Variables Setup
# ============================================
# This file contains all environment variables needed for production deployment
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE (Required for production)
# ============================================
# PostgreSQL database connection string
# Format: postgresql://user:password@host:port/database
# For Vercel/Railway: Use the provided PostgreSQL connection string
DATABASE_URL=postgresql://username:password@your-db-host:5432/soulyatri

# ============================================
# AUTHENTICATION (Required)
# ============================================
# JWT Secret - must be at least 32 characters long
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# JWT Expiration times
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============================================
# CORS & FRONTEND (Required for production)
# ============================================
# Your Vercel frontend URL
# Example: https://soul-yatri.vercel.app
CORS_ORIGIN=https://your-app.vercel.app

# ============================================
# SERVER CONFIG (Optional)
# ============================================
# Port - Vercel/Railway will provide this automatically
PORT=3000

# Environment
NODE_ENV=production

# ============================================
# OPTIONAL SERVICES
# ============================================

# Email Service (Optional - for notifications)
EMAIL_PROVIDER=console
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=Soul Yatri <noreply@soulyatri.com>

# File Storage (Optional - for uploads)
STORAGE_PROVIDER=memory
STORAGE_BUCKET=your-bucket-name
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key

# Payment Gateway (Optional - for payments)
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Video Calls (Optional - for sessions)
DAILY_API_KEY=your-daily-api-key

# AI Integration (Optional - for AI features)
OPENAI_API_KEY=your-openai-api-key

# ============================================
# SETUP INSTRUCTIONS
# ============================================

# 1. DATABASE SETUP (Required)
#    - Create PostgreSQL database on Railway, Supabase, or Neon
#    - Copy the connection string to DATABASE_URL
#    - Run migrations: npx prisma migrate deploy

# 2. JWT SECRET (Required)
#    - Generate: openssl rand -base64 32
#    - Or use: https://generate-secret.vercel.app/32
#    - Copy to JWT_SECRET

# 3. CORS ORIGIN (Required for production)
#    - Get your Vercel URL after deployment
#    - Add to CORS_ORIGIN

# 4. DEPLOY TO VERCEL
#    - Add environment variables in Vercel Dashboard
#    - Deploy backend

# 5. CREATE TEST ACCOUNTS (Optional)
#    - After database is connected, run:
#      cd server && npm run seed:test

# ============================================
