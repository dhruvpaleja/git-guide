{
  "name": "soul-yatri-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:ci": "eslint src/ --ext .ts --max-warnings 0",
    "seed": "tsx prisma/seed-dev.ts",
    "seed:therapists": "tsx src/seeds/seed-therapists.ts",
    "seed:test": "tsx scripts/create-test-accounts.ts",
    "db:reset": "npx prisma migrate reset --force && npm run seed:dev",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "test:pricing": "tsx tests/test-pricing-progression.mjs",
    "test:cancellation": "tsx tests/test-cancellation-rules.mjs",
    "test:therapist-limit": "tsx tests/test-therapist-limit.mjs",
    "test:nudge": "tsx tests/test-nudge-system.mjs",
    "test:flow": "tsx tests/test-full-booking-flow.mjs",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.0",
    "pg": "^8.19.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^3.25.67",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.16.4",
    "@types/ws": "^8.18.1",
    "@types/zxcvbn": "^4.4.5",
    "prisma": "^7.4.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  }
}
